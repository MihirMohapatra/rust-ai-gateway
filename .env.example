OLLAMA_BASE_URL=http://localhost:11434

# Security
JWT_SECRET=change-this-to-a-random-secret-in-production

# Rate Limiting
GLOBAL_RATE_LIMIT=1000

# Logging
RUST_LOG=gateway=debug,tower_http=debug

