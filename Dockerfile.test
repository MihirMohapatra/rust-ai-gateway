# Test Dockerfile - runs cargo test inside a container
FROM rust:1.82-slim

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .

# Build all tests first (cached layer)
RUN cargo build --tests 2>&1

# Run all tests
CMD ["cargo", "test", "--workspace", "--", "--nocapture"]

